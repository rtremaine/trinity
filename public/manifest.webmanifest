{
  "name": "Trinity",
  "short_name": "Trinity",
  "description": "Next.js + Postgres app with auth, roles, and audit logging.",
  "start_url": "/",
  "scope": "/",
  "display": "standalone",
  "orientation": "portrait",
  "background_color": "#0a0a0a",
